# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

project_id = "your-gcp-project-id"
region     = "asia-south1"
zone       = "asia-south1-a"

# Set to true to auto-bootstrap a kubeadm cluster with Calico + Helm
# Set to false (default) to practice kubeadm init/join manually
# auto_cluster = true

# Kubernetes version (default: 1.34)
# k8s_version = "1.34"

# Machine types (defaults shown)
# controlplane_machine_type = "e2-standard-2"
# worker_machine_type       = "e2-medium"
# worker_count              = 2
